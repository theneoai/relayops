# Agent Platform MVP — 环境变量模板
# 复制为 .env 后运行 make init 自动生成密钥

# 基础配置
NODE_ENV=development
LOG_LEVEL=info
VERSION=0.2.0

# 数据库
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agent_platform
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/agent_platform

# Redis
REDIS_URL=redis://redis:6379/0

# JWT（运行 make init 自动生成）
JWT_SECRET=auto-generated-by-init

# Ollama（本地LLM，需 make up-all 启动）
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# LiteLLM Proxy（统一LLM网关）
LITELLM_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-relayops-master-key

# 外部LLM（可选，MVP优先用Ollama）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 服务发现（Compose网络内DNS）
DEVKIT_API_URL=http://devkit-api:8080
ORCHESTRATOR_URL=http://orchestrator:8081
TOOL_SERVICE_URL=http://tool-service:8083
MCP_SERVER_URL=http://mcp-server:8084

# Langfuse 可观测性
LANGFUSE_BASEURL=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Flowise
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=changeme

# Grafana
GRAFANA_PASSWORD=admin
